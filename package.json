{
  "name": "@wyrd-company/ahp-server",
  "version": "0.1.0",
  "description": "Production-shaped TypeScript Agent Host Protocol server with pluggable agent adapters.",
  "type": "module",
  "license": "MIT",
  "author": "Wyrd Company",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyrd-company/ahp-server.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "ahp-server": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./codex-app-server": {
      "import": "./dist/src/codex-app-server/index.js",
      "types": "./dist/src/codex-app-server/index.d.ts"
    },
    "./claude-agent-sdk": {
      "import": "./dist/src/claude-agent-sdk/index.js",
      "types": "./dist/src/claude-agent-sdk/index.d.ts"
    },
    "./grpc": {
      "import": "./dist/src/grpc/index.js",
      "types": "./dist/src/grpc/index.d.ts"
    },
    "./nats": {
      "import": "./dist/src/nats/index.js",
      "types": "./dist/src/nats/index.d.ts"
    },
    "./process": {
      "import": "./dist/src/process/index.js",
      "types": "./dist/src/process/index.d.ts"
    },
    "./pi-agent": {
      "import": "./dist/src/pi-agent/index.js",
      "types": "./dist/src/pi-agent/index.d.ts"
    },
    "./provider-kit": {
      "import": "./dist/src/provider-kit.js",
      "types": "./dist/src/provider-kit.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "node --test --import tsx test/*.test.ts",
    "test:live:claude": "scripts/validate-live-claude-agent-sdk.sh",
    "test:live:pi": "scripts/validate-live-pi-agent.sh",
    "test:live:process": "scripts/validate-live-server-process.sh",
    "test:live:resources": "scripts/validate-live-resources.sh",
    "test:live:vertical": "scripts/validate-live-vertical.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.170",
    "@microsoft/agent-host-protocol": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nats-io/transport-node": "^3.4.0",
    "@wyrd-company/ahp-codex-app-server": "file:../ahp-codex-app-server",
    "@wyrd-company/ahp-grpc": "file:../ahp-grpc",
    "@wyrd-company/ahp-nats": "file:../ahp-nats",
    "@wyrd-company/ahp-provider-kit": "file:../ahp-provider-kit",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
